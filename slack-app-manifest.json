{
  "display_information": {
    "name": "Mission Control",
    "description": "Multi-agent team: orchestrator, managers en specialisten in eigen kanalen.",
    "background_color": "#07070f"
  },
  "features": {
    "bot_user": {
      "display_name": "Mission Control",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/agents",
        "url": "https://REPLACE_WITH_YOUR_DOMAIN/api/slack/commands",
        "description": "Lijst van alle agents en kanalen",
        "should_escape": false
      },
      {
        "command": "/agent",
        "url": "https://REPLACE_WITH_YOUR_DOMAIN/api/slack/commands",
        "description": "Info over één specifieke agent",
        "usage_hint": "mgr-ad",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "channels:manage",
        "channels:read",
        "chat:write",
        "chat:write.public",
        "commands",
        "groups:history",
        "groups:read",
        "groups:write",
        "im:history",
        "im:read",
        "im:write",
        "mpim:history",
        "mpim:read",
        "mpim:write",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://REPLACE_WITH_YOUR_DOMAIN/api/slack/events",
      "bot_events": [
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
